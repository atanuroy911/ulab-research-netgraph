    "Machine Learning, Data Science and Natural Language Processing"
  ],
  "education": [
    {
      "raw": "Education\nMSc\n, Institute of Information Technology, University of Dhaka, August 2022.\nThesis: Dataset size-invariant feature reduction techniques to find interactive independent feature for classification\nSupervisor: Professor Mohammad Shoyaib, Institute of Information Technology, University of Dhaka\nBSc\n, Institute of Information Technology, University of Dhaka, December 2019."
    }
  ],
  "publications_raw": [
