  "id": "prof-muhammad-ibrahim-phd",
  "name": "Prof. Muhammad Ibrahim, PhD",
  "title": "Professor",
  "department": "General Education Program (GED)",
  "school": "",
  "profile_url": "https://ulab.edu.bd/faculty/prof-muhammad-ibrahim-phd",
