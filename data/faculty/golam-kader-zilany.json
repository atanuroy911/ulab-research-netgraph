  "id": "golam-kader-zilany",
  "name": "Golam Kader Zilany",
  "title": "Senior Lecturer",
  "department": "Department of English & Humanities (DEH)",
  "school": "",
  "profile_url": "https://ulab.edu.bd/faculty/golam-kader-zilany",
